# API 密钥配置示例
# 根据你使用的 LLM 提供商，配置对应的 API 密钥

# DeepSeek API 密钥（默认）
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# OpenAI API 密钥（可选）
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_BASE_URL=https://sg.uiuiapi.com/v1/
OPENAI_EMBEDDING_MODEL=text-embedding-ada-002
OPENAI_API_STYLE=auto
DOCKER_PATH=

# 独立的 Embedding 配置（RAG / 长期记忆）
EMBEDDING_PROVIDER=openai
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=https://sg.uiuiapi.com/v1/
EMBEDDING_MODEL=text-embedding-ada-002
EMBEDDING_DIMENSION=1536

# Claude (Anthropic) API 密钥（可选）
CLAUDE_API_KEY=your_claude_api_key_here

# Google Gemini API 密钥（可选）
GEMINI_API_KEY=your_gemini_api_key_here
